<div class="my-5">
    <h1 class="text-center">교수관리</h1>
    <div class="text-end mb-2">
        <a class="btn btn-primary px-3" href="/haksa/pro/insert">교수등록</a>
    </div>
    <table id="tb1" class="table table-striped table-hover"></table>
    <script id="temp" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}
                <tr>
                    <td>{{PCODE}}</td>
                    <td>{{PNAME}}</td>
                    <td>{{DEPT}}</td>
                    <td>{{TITLE}}</td>
                    <td>{{FDATE}}</td>
                    <td>{{FSALARY}}</td>
                    <td><button class="btn btn-outline-danger btn-sm delete" pcode="{{PCODE}}">삭제</button></td>
                </tr>
            {{/each}}
        </tbody>
    </script>
</div>
<script>
    getList();
    $("#tb1").on("click", ".delete", function(){
        const pcode=$(this).attr("pcode");
        if(confirm(`${pcode}번 교수를 삭제하실래요?`)) {
            $.ajax({
                type:"post",
                url:"/haksa/pro/delete",
                data:{pcode},
                success:function() {
                    alert("삭제가 완료되었습니다.");
                    getList();
                },
                error:function(){
                    alert("삭제를 실패했습니다.");
                }
            })
        }
    });
    function getList() {
        $.ajax({
            type:"get",
            url:"/haksa/pro/list.json",
            success:function(data){
                console.log(data);
                const temp=Handlebars.compile($("#temp").html());
                $("#tb1").html(temp(data));
            }
        })
    }
</script>